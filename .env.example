# =============================================================================
# Y Website — environment variables
# =============================================================================
# Copy this file to `.env.local` for local dev, and set the same values in
# Vercel → Project Settings → Environment Variables for preview + production.
# Variables prefixed `NEXT_PUBLIC_` are exposed to the browser; all others
# are server-only (API routes, server components).
# =============================================================================


# ── Site config (REQUIRED in production) ────────────────────────────────────

# Absolute canonical URL of the site. Drives `metadataBase`, every page's
# canonical tag, OG image URLs, sitemap.xml, robots.txt, and JSON-LD schemas.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://example.com


# ── Company registration (OPTIONAL) ─────────────────────────────────────────

# When all three are set, the footer renders a compliance line below the
# copyright. Leave blank to hide the line entirely.
NEXT_PUBLIC_COMPANY_LEGAL_NAME=
NEXT_PUBLIC_COMPANY_NUMBER=
NEXT_PUBLIC_VAT_NUMBER=


# ── Analytics (OPTIONAL) ────────────────────────────────────────────────────

# Plausible Analytics — set to your registered domain to activate.
# Example: NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yguildford.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Plausible self-hosted instance — only set if not using plausible.io.
# Example: NEXT_PUBLIC_PLAUSIBLE_HOST=https://stats.example.com
NEXT_PUBLIC_PLAUSIBLE_HOST=


# ── Error tracking (OPTIONAL) ───────────────────────────────────────────────

# Sentry DSN — when set, server-side errors are forwarded to Sentry.
# Get this from: Sentry → Project Settings → Client Keys (DSN).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=


# ── Email provider (OPTIONAL — for production form submissions) ─────────────

# When `RESEND_API_KEY` is set, the venue-hire / members / newsletter API
# routes will forward submissions to barmanager@dreamoyster.com via Resend.
# Until then, submissions are logged server-side only (visible in Vercel
# function logs).
RESEND_API_KEY=

# Email that receives venue-hire enquiries
ENQUIRIES_INBOX=barmanager@dreamoyster.com

# Verified sender identity for Resend. Use a domain you have verified in
# Resend before sending to real guests.
EMAIL_FROM="Y Guildford <hello@example.com>"
